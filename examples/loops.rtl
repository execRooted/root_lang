use("../stdlib/root.rtl") aka std;

fn main() gives void {
    int n = 5;
    std.emit("Countdown: ");
    loop (n > 0) {
        std.emit(n);
        std.emit(" ");
        n -= 1;
    }
    std.line();

    std.emit("Evens: ");
    walk (int i = 0, i < 10, i += 1) {
        when (i % 2 != 0) { skip; }
        when (i > 8) { stop; }
        std.emit(i);
        std.emit(" ");
    }
    std.line();
}
