use("../stdlib/root.rtl") aka std;

fn total(int[] nums, int size) gives int {
    int sum = 0;
    walk (int i = 0, i < size, i += 1) {
        sum += nums[i];
    }
    give sum;
}

fn main() gives void {
    int[] nums = {1, 2, 3, 4, 5};
    std.emit("Length: ");
    std.emit(nums.length);
    std.line();

    nums[0] = 10;
    std.emit("First: ");
    std.emit(nums[0]);
    std.line();

    std.emit("Sum: ");
    std.emit(total(nums, nums.length));
    std.line();
}
