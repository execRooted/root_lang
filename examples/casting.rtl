use("../stdlib/root.rtl") aka std;

fn main() gives void {
    float pi = 3.14;
    int truncated = pi to int;
    std.emit("pi as int: ");
    std.emit(truncated);
    std.line();

    int big = 300;
    int8 small = big to int8;
    std.emit("300 as int8: ");
    std.emit(small);
    std.line();

    double d = 2.0;
    std.emit("sqrt(2) squared area of a 2x2: ");
    std.emit(std.root(4.0));
    std.line();
}
